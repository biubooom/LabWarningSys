# Build directories
build/
Debug/
Release/

# CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
Makefile
*.ninja

# STM32CubeMX generated files (if any)
*.ioc.bak
*.mxproject

# FreeRTOS build artifacts (if generated)
FreeRTOS/Source/portable/*/build/
FreeRTOS/Source/portable/*/*.o
FreeRTOS/Source/portable/*/*.a

# HAL Driver build artifacts
Drivers/STM32F1xx_HAL_Driver/Src/*.o
Drivers/STM32F1xx_HAL_Driver/Inc/*.tmp

# Core source build artifacts
Core/Src/*.o
Core/Inc/*.tmp

# Startup and linker files (if modified, but typically not)
# startup_stm32f103xe.s (uncomment if you want to ignore customizations)
# STM32F103XX_FLASH.ld (uncomment if you want to ignore customizations)

# VS Code workspace and settings
.vscode/
*.code-workspace

# Temporary files
*.tmp
*.bak
*.swp
*.swo
*~

# OS-specific files
Thumbs.db
.DS_Store
*.log

# Toolchain-specific files (e.g., arm-none-eabi)
*.elf
*.hex
*.bin
*.map
*.lst

# Other common ignores
.idea/
*.sublime-project
*.sublime-workspace