page {
  min-height: 100%;
  background: #f5f1ea;
  color: #17313b;
}

.page {
  min-height: 100%;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.16), transparent 30%),
    linear-gradient(180deg, #18343a 0rpx, #27464b 180rpx, #f5f1ea 181rpx, #f5f1ea 100%);
}

.header-card,
.selector-card,
.summary-card,
.prediction-card,
.chart-card,
.state-card {
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 36rpx rgba(20, 42, 44, 0.08);
  margin-bottom: 18rpx;
}

.header-card__title {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
}

.header-card__subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
}

.header-card {
  background: transparent;
  box-shadow: none;
  padding: 6rpx 4rpx 14rpx;
}

.selector-card__label {
  font-size: 24rpx;
  color: #6d7f86;
  margin-bottom: 14rpx;
}

.selector-card__label--spaced {
  margin-top: 12rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(24, 52, 58, 0.06);
  color: #355059;
  font-size: 24rpx;
  font-weight: 600;
}

.chip--active {
  background: #18343a;
  color: #ffffff;
}

.summary-card__label {
  font-size: 22rpx;
  color: #6d7f86;
  margin-bottom: 8rpx;
}

.summary-card__value {
  font-size: 48rpx;
  font-weight: 700;
  color: #18343a;
}

.summary-card__unit {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: #71838a;
}

.prediction-card__label {
  font-size: 22rpx;
  color: #6d7f86;
  margin-bottom: 8rpx;
}

.prediction-card__value {
  font-size: 30rpx;
  font-weight: 700;
  color: #18343a;
  line-height: 1.5;
}

.history-canvas {
  width: 100%;
  box-sizing: border-box;
  height: 360rpx;
  display: block;
}

.state-card {
  font-size: 24rpx;
  color: #5d6d73;
}

.state-card--error {
  color: #9b3f27;
  background: #fff1ea;
}
